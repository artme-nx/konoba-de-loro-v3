{
  "$schema": "https://design-tokens.org/schema.json",
  "primitive": {
    "color": {
      "linen": {
        "50": { "$value": "#FBF7EC", "$type": "color" },
        "100": { "$value": "#F4EAD1", "$type": "color" },
        "300": { "$value": "#E2CFA0", "$type": "color" },
        "500": { "$value": "#A6926E", "$type": "color" }
      },
      "notte": {
        "950": { "$value": "#181320", "$type": "color" },
        "900": { "$value": "#221B2C", "$type": "color" },
        "800": { "$value": "#332942", "$type": "color" },
        "700": { "$value": "#463A59", "$type": "color" }
      },
      "cobalt": {
        "400": { "$value": "#5B87C9", "$type": "color" },
        "500": { "$value": "#33619E", "$type": "color" },
        "700": { "$value": "#20406C", "$type": "color" },
        "900": { "$value": "#122642", "$type": "color" }
      },
      "ochre": {
        "400": { "$value": "#E3A53E", "$type": "color" },
        "500": { "$value": "#C6841F", "$type": "color" },
        "700": { "$value": "#8C5A12", "$type": "color" }
      }
    },
    "font": {
      "display": { "$value": "var(--font-petrona), 'Petrona', Georgia, serif", "$type": "fontFamily" },
      "sans": { "$value": "var(--font-figtree), system-ui, sans-serif", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "180ms", "$type": "duration" },
        "base": { "$value": "320ms", "$type": "duration" },
        "reveal": { "$value": "1.1s", "$type": "duration" },
        "cine": { "$value": "1.8s", "$type": "duration" }
      },
      "ease": {
        "out-expo": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
        "cine": { "$value": "cubic-bezier(0.65, 0, 0.35, 1)", "$type": "cubicBezier" }
      }
    },
    "tracking": {
      "display": { "$value": "-0.01em", "$type": "dimension" },
      "label": { "$value": "0.26em", "$type": "dimension" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.linen.50}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.notte.950}", "$type": "color" },
    "card": { "$value": "{primitive.color.linen.100}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.notte.950}", "$type": "color" },
    "muted": { "$value": "{primitive.color.linen.100}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.linen.500}", "$type": "color" },
    "accent": { "$value": "{primitive.color.linen.300}", "$type": "color" },
    "accent-foreground": { "$value": "{primitive.color.notte.950}", "$type": "color" },
    "border": { "$value": "{primitive.color.linen.300}", "$type": "color" },
    "ring": { "$value": "{primitive.color.cobalt.500}", "$type": "color" },
    "radius": { "$value": "0.85rem", "$type": "dimension" },
    "ink": { "$value": "{primitive.color.notte.950}", "$type": "color" },
    "ink-card": { "$value": "{primitive.color.notte.900}", "$type": "color" },
    "ink-border": { "$value": "{primitive.color.notte.700}", "$type": "color" },
    "cobalt": { "$value": "{primitive.color.cobalt.500}", "$type": "color" },
    "cobalt-dim": { "$value": "{primitive.color.cobalt.900}", "$type": "color" },
    "ochre": { "$value": "{primitive.color.ochre.500}", "$type": "color" },
    "surface-line": { "$value": "{primitive.color.linen.300}", "$type": "color" },
    "type-display": { "$value": "{primitive.font.display}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.sans}", "$type": "fontFamily" },
    "ease-reveal": { "$value": "{primitive.motion.ease.out-expo}", "$type": "cubicBezier" },
    "ease-cine": { "$value": "{primitive.motion.ease.cine}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-reveal": { "$value": "{primitive.motion.duration.reveal}", "$type": "duration" },
    "tracking-display": { "$value": "{primitive.tracking.display}", "$type": "dimension" },
    "tracking-label": { "$value": "{primitive.tracking.label}", "$type": "dimension" }
  },
  "component": {
    "hero": {
      "title-size": { "$value": "clamp(2.6rem, 7vw, 5.8rem)", "$type": "dimension" },
      "title-leading": { "$value": "1.04", "$type": "number" },
      "glow": {
        "$value": "radial-gradient(ellipse 70% 50% at 50% 100%, rgba(230, 175, 80, 0.16), rgba(24, 19, 32, 0.05) 45%, transparent 72%)",
        "$type": "gradient"
      },
      "vignette": {
        "$value": "linear-gradient(to top, rgba(24, 19, 32, 0.92) 0%, rgba(24, 19, 32, 0.22) 45%, rgba(24, 19, 32, 0.5) 100%)",
        "$type": "gradient"
      }
    },
    "button": {
      "primary-bg": { "$value": "{primitive.color.cobalt.500}", "$type": "color" },
      "primary-fg": { "$value": "#FBF7EC", "$type": "color" },
      "primary-hover-bg": { "$value": "{primitive.color.cobalt.700}", "$type": "color" },
      "ghost-border": { "$value": "rgba(24, 19, 32, 0.22)", "$type": "color" },
      "ghost-hover-border": { "$value": "{primitive.color.cobalt.500}", "$type": "color" }
    }
  }
}
